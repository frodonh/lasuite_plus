{
	"manifest_version": 3,
	"name": "Print Docs",
	"version": "1.0",
	"description": "Une extension pour convertir les fichiers Docs en documents imprimables",
	"icons": {
		"48": "print-docs-inactive-48.png",
		"128": "print-docs-inactive-128.png"
	},
	"action": {
		"default_icon": "print-docs-inactive.svg",
		"default_title": "Exporter sous le modèle d'entreprise",
		"default_popup": "popup.htm"
	},
	"options_page": "select_css.html",
	"permissions": ["storage", "activeTab", "scripting", "unlimitedStorage", "tabs", "downloads"],
	"host_permissions": ["*://docs.numerique.gouv.fr/docs/*"],
	"background": {
		"service_worker": "background.js",
		"scripts": ["background.js"],
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": ["https://docs.numerique.gouv.fr/docs/*"],
			"js": ["content.js"]
		}
	],
	"web_accessible_resources": [
		{ 
			"resources": ["paged.polyfill.min.js", "interface.css", "base_templates.json", "content-paged.js"],
			"matches": ["<all_urls>"]
		} 
	]
}
